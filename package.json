{
    "name": "storescope-ai",
    "version": "0.1.0",
    "private": true,
    "description": "StoreScope AI - Retail analytics and AI product recommendation platform",
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "generate:manifest": "ts-node --project tsconfig.scripts.json scripts/extract-products.ts",
        "collect:prices": "ts-node --project tsconfig.scripts.json scripts/collect-prices.ts",
        "move:compile": "cd contracts/aptos && aptos move compile",
        "move:test": "cd contracts/aptos && aptos move test",
        "move:publish": "cd contracts/aptos && aptos move publish",
        "move:deploy": "scripts/deploy-contract.sh",
        "move:deploy:win": "powershell -ExecutionPolicy Bypass -File scripts/deploy-contract.ps1"
    },
    "dependencies": {
        "@aptos-labs/ts-sdk": "^5.1.1",
        "@aptos-labs/wallet-adapter-react": "^8.3.1",
        "@shelby-protocol/sdk": "latest",
        "@telegram-apps/bridge": "^2.11.0",
        "aptos": "^1.22.1",
        "buffer": "^6.0.3",
        "csv-parse": "^6.1.0",
        "csv-stringify": "^6.6.0",
        "eventemitter3": "^5.0.4",
        "got": "^14.6.6",
        "lucide-react": "^0.577.0",
        "next": "16.1.6",
        "petra-plugin-wallet-adapter": "^0.4.5",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "uuid": "^13.0.0",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9",
        "eslint-config-next": "16.1.6",
        "tailwindcss": "^4",
        "ts-node": "^10.9.2",
        "typescript": "^5"
    }
}
